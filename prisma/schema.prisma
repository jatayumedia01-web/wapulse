generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Multi-Tenant Core ──────────────────────────────────────────────────────

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logoUrl     String   @default("")
  timezone    String   @default("Asia/Kolkata")
  plan        String   @default("FREE") // FREE | STARTER | GROWTH | BUSINESS | ENTERPRISE
  trialEndsAt DateTime?
  createdAt   DateTime @default(now())

  users         User[]
  subscriptions Subscription[]
  settings      Setting[]
  contacts      Contact[]
  conversations Conversation[]
  templates     Template[]
  campaigns     Campaign[]
  automationRules AutomationRule[]
  flows         Flow[]
  quickReplies  QuickReply[]
  products      Product[]
  orders        Order[]
  dripSequences DripSequence[]
  customFields  CustomField[]
  forms         Form[]
  webhookEndpoints WebhookEndpoint[]
  apiKeys       ApiKey[]
  usageLogs     UsageLog[]
  invitations   Invitation[]
  billingEvents BillingEvent[]
  auditLogs     AuditLog[]
  teamMembers   TeamMember[]
}

model User {
  id            String       @id @default(cuid())
  orgId         String
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name          String
  email         String
  passwordHash  String       @default("")
  role          String       @default("AGENT") // SUPER_ADMIN | ADMIN | AGENT | VIEWER
  emailVerified Boolean      @default(false)
  avatarUrl     String       @default("")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  sessions      Session[]
  auditLogs     AuditLog[]
  passwordResets PasswordReset[]

  @@unique([orgId, email])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model Invitation {
  id          String       @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  email       String
  role        String       @default("AGENT")
  token       String       @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime     @default(now())
}

model Subscription {
  id                String       @id @default(cuid())
  orgId             String
  org               Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  plan              String       // FREE | STARTER | GROWTH | BUSINESS | ENTERPRISE
  status            String       @default("ACTIVE") // ACTIVE | PAST_DUE | CANCELLED | TRIALING
  razorpaySubId     String       @default("")
  razorpayCustomerId String      @default("")
  currentPeriodEnd  DateTime?
  cancelAtEnd       Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model UsageLog {
  id           String       @id @default(cuid())
  orgId        String
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  month        String       // YYYY-MM
  contacts     Int          @default(0)
  messagesSent Int          @default(0)
  campaigns    Int          @default(0)
  apiCalls     Int          @default(0)
  updatedAt    DateTime     @updatedAt

  @@unique([orgId, month])
}

model BillingEvent {
  id          String       @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  type        String       // subscription.created | payment.success | payment.failed | subscription.cancelled
  amount      Float        @default(0)
  currency    String       @default("INR")
  razorpayId  String       @default("")
  meta        String       @default("{}")
  createdAt   DateTime     @default(now())
}

model AuditLog {
  id         String       @id @default(cuid())
  orgId      String
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?        @relation(fields: [userId], references: [id])
  action     String       // e.g. "contact.created", "message.sent", "setting.updated"
  resource   String       @default("")
  before     String       @default("{}")
  after      String       @default("{}")
  createdAt  DateTime     @default(now())

  @@index([orgId, createdAt])
}

// ── Business Data (all scoped to orgId) ────────────────────────────────────

model Contact {
  id            String         @id @default(cuid())
  orgId         String
  org           Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  phone         String
  name          String?
  email         String?
  tags          String         @default("")
  attributes    String         @default("{}")
  optedIn       Boolean        @default(true)
  score         Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  conversations Conversation[]
  campaignSends CampaignSend[]
  orders        Order[]
  dripEnrolments DripEnrolment[]
  events        ContactEvent[]
  formResponses FormResponse[]

  @@unique([orgId, phone])
  @@index([orgId])
}

model Conversation {
  id            String    @id @default(cuid())
  orgId         String
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contactId     String
  contact       Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  status        String    @default("OPEN") // OPEN | PENDING | RESOLVED | SNOOZED
  assignee      String?
  labels        String    @default("")
  flowState     String    @default("{}")
  aiEnabled     Boolean   @default(true)
  unread        Int       @default(0)
  snoozedUntil  DateTime?
  firstResponseAt DateTime?
  csatScore     Int?      // 1-5
  csatSentAt    DateTime?
  lastMessageAt DateTime  @default(now())
  createdAt     DateTime  @default(now())
  messages      Message[]

  @@index([orgId, status])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  direction      String
  kind           String       @default("MESSAGE")
  type           String       @default("text")
  body           String
  author         String?
  status         String       @default("SENT")
  waMessageId    String?
  meta           String       @default("{}")
  sentiment      String?
  isAi           Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

model Template {
  id            String     @id @default(cuid())
  orgId         String
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name          String
  category      String     @default("MARKETING")
  language      String     @default("en")
  headerType    String     @default("TEXT")
  mediaUrl      String     @default("")
  header        String?
  body          String
  footer        String?
  buttons       String     @default("[]")
  carouselCards String     @default("[]")
  isLTO         Boolean    @default(false)
  ltoExpiry     DateTime?
  couponCode    String     @default("")
  status        String     @default("DRAFT")
  createdAt     DateTime   @default(now())
  campaigns     Campaign[]
  dripSteps     DripStep[]

  @@unique([orgId, name])
  @@index([orgId])
}

model Campaign {
  id           String         @id @default(cuid())
  orgId        String
  org          Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name         String
  templateId   String
  template     Template       @relation(fields: [templateId], references: [id])
  audienceTag  String         @default("")
  retargetOfId String?
  status       String         @default("DRAFT")
  scheduledAt  DateTime?
  retryEnabled Boolean        @default(false)
  retryAfterHrs Int           @default(24)
  retryCount   Int            @default(0)
  total        Int            @default(0)
  sent         Int            @default(0)
  delivered    Int            @default(0)
  read         Int            @default(0)
  replied      Int            @default(0)
  failed       Int            @default(0)
  createdAt    DateTime       @default(now())
  sends        CampaignSend[]

  @@index([orgId])
}

model CampaignSend {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId  String
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  status     String   @default("SENT")
  retryCount Int      @default(0)
  createdAt  DateTime @default(now())
}

model AutomationRule {
  id        String   @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name      String
  trigger   String   @default("KEYWORD")
  keywords  String   @default("")
  matchType String   @default("contains")
  reply     String   @default("")
  enabled   Boolean  @default(true)
  priority  Int      @default(0)
  hits      Int      @default(0)
  createdAt DateTime @default(now())

  @@index([orgId])
}

model DripSequence {
  id           String          @id @default(cuid())
  orgId        String
  org          Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name         String
  triggerType  String          @default("MANUAL")
  triggerEvent String          @default("")
  triggerTag   String          @default("")
  enabled      Boolean         @default(true)
  enrollCount  Int             @default(0)
  createdAt    DateTime        @default(now())
  steps        DripStep[]
  enrolments   DripEnrolment[]

  @@index([orgId])
}

model DripStep {
  id         String       @id @default(cuid())
  sequenceId String
  sequence   DripSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  stepNumber Int
  templateId String?
  template   Template?    @relation(fields: [templateId], references: [id])
  message    String       @default("")
  delayValue Int          @default(1)
  delayUnit  String       @default("hours")
  createdAt  DateTime     @default(now())

  @@unique([sequenceId, stepNumber])
}

model DripEnrolment {
  id          String       @id @default(cuid())
  sequenceId  String
  sequence    DripSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  contactId   String
  contact     Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  currentStep Int          @default(0)
  status      String       @default("ACTIVE")
  nextSendAt  DateTime
  createdAt   DateTime     @default(now())

  @@unique([sequenceId, contactId])
}

model CustomField {
  id        String       @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name      String
  key       String
  type      String       @default("text")
  options   String       @default("[]")
  createdAt DateTime     @default(now())

  @@unique([orgId, key])
}

model ContactEvent {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  event     String
  data      String   @default("{}")
  createdAt DateTime @default(now())

  @@index([contactId, event])
}

model Form {
  id          String         @id @default(cuid())
  orgId       String
  org         Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String
  description String         @default("")
  fields      String         @default("[]")
  enabled     Boolean        @default(true)
  responses   FormResponse[]
  createdAt   DateTime       @default(now())

  @@index([orgId])
}

model FormResponse {
  id        String   @id @default(cuid())
  formId    String
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  answers   String   @default("{}")
  createdAt DateTime @default(now())
}

model ApiKey {
  id         String       @id @default(cuid())
  orgId      String
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name       String
  key        String       @unique
  createdAt  DateTime     @default(now())
  lastUsedAt DateTime?

  @@index([orgId])
}

model Setting {
  id            String       @id @default(cuid())
  orgId         String       @unique
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  businessName  String       @default("")
  phoneNumberId String       @default("")
  wabaId        String       @default("")
  accessToken   String       @default("")
  verifyToken   String       @default("wapulse_verify")
  openaiApiKey  String       @default("")
  aiPersona     String       @default("You are a friendly, concise customer support agent.")
  awayMessage   String       @default("Thanks for reaching out! Our team is currently away — we'll get back to you shortly.")
  awayEnabled   Boolean      @default(false)
  workStart     String       @default("09:00")
  workEnd       String       @default("19:00")
  workDays      String       @default("1,2,3,4,5,6")
  autoAssign    Boolean      @default(true)
  demoMode      Boolean      @default(true)
  onboarded     Boolean      @default(false)
}

model TeamMember {
  id        String       @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name      String
  email     String
  role      String       @default("AGENT")
  createdAt DateTime     @default(now())

  @@unique([orgId, email])
  @@index([orgId])
}

model QuickReply {
  id        String       @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  shortcut  String
  body      String
  createdAt DateTime     @default(now())

  @@unique([orgId, shortcut])
  @@index([orgId])
}

model Product {
  id          String       @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String
  description String       @default("")
  price       Float
  currency    String       @default("INR")
  imageUrl    String       @default("")
  sku         String       @default("")
  inStock     Boolean      @default(true)
  createdAt   DateTime     @default(now())

  @@index([orgId])
}

model Order {
  id          String       @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contactId   String
  contact     Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  items       String       @default("[]")
  total       Float
  status      String       @default("PENDING")
  paymentLink String       @default("")
  campaignId  String?
  dripId      String?
  createdAt   DateTime     @default(now())

  @@index([orgId])
}

model Flow {
  id        String       @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name      String
  keywords  String       @default("")
  nodes     String       @default("[]")
  enabled   Boolean      @default(true)
  runs      Int          @default(0)
  createdAt DateTime     @default(now())

  @@index([orgId])
}

model WebhookEndpoint {
  id          String       @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  url         String
  events      String       @default("message.received,message.sent")
  secret      String       @default("")
  enabled     Boolean      @default(true)
  lastStatus  Int          @default(0)
  lastFiredAt DateTime?
  createdAt   DateTime     @default(now())

  @@index([orgId])
}
